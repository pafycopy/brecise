{
  "expo": {
    "name": "Brecise",
    "slug": "brecise",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/images/icon-1024-white-bg.png",
    "scheme": "brecise",
    "userInterfaceStyle": "automatic",
    "newArchEnabled": true,
    "ios": {
      "supportsTablet": true,
      "infoPlist": {
        "UIBackgroundModes": ["location"],
        "NSLocationAlwaysAndWhenInUseUsageDescription": "Brecise menggunakan lokasi untuk melacak jarak dan rute lari kamu, termasuk saat layar HP mati.",
        "NSLocationWhenInUseUsageDescription": "Brecise menggunakan lokasi untuk melacak jarak dan rute lari kamu."
      }
    },
    "android": {
      "adaptiveIcon": {
        "backgroundColor": "#ffffff",
        "foregroundImage": "./assets/images/adaptive-icon-foreground-1024.png",
        "monochromeImage": "./assets/images/notification-icon.png"
      },
      "edgeToEdgeEnabled": true,
      "predictiveBackGestureEnabled": false,
      "package": "com.brecise.app",
      "permissions": [
        "ACCESS_COARSE_LOCATION",
        "ACCESS_FINE_LOCATION",
        "ACCESS_BACKGROUND_LOCATION",
        "FOREGROUND_SERVICE",
        "FOREGROUND_SERVICE_LOCATION"
      ]
    },
    "web": {
      "output": "static",
      "favicon": "./assets/images/icon-1024-white-bg.png"
    },
    "plugins": [
      "expo-router",
      [
        "expo-splash-screen",
        {
          "image": "./assets/images/breciselogo.png",
          "imageWidth": 200,
          "resizeMode": "contain",
          "backgroundColor": "#ffffff"
        }
      ],
      "expo-audio",
      [
        "expo-image-picker",
        {
          "photosPermission": "Izinkan Brecise mengakses galeri untuk foto profil.",
          "cameraPermission": "Izinkan Brecise menggunakan kamera untuk foto profil."
        }
      ],
      "expo-secure-store",
      "expo-web-browser",
      "expo-font",
      "@react-native-community/datetimepicker",
      [
        "expo-notifications",
        {
          "icon": "./assets/images/notification-icon.png",
          "color": "#6BFF8F",
          "sounds": []
        }
      ],
      [
        "react-native-google-mobile-ads",
        {
          "androidAppId": "ca-app-pub-6314173942507588~5724896127",
          "iosAppId": "ca-app-pub-4673696615107294~2220067287"
        }
      ],
      "react-native-iap",
      [
        "expo-location",
        {
          "locationAlwaysAndWhenInUsePermission": "Brecise menggunakan lokasi untuk melacak jarak dan rute lari kamu, termasuk saat layar HP mati.",
          "locationAlwaysPermission": "Brecise melacak lari kamu di latar belakang saat layar HP mati.",
          "isAndroidBackgroundLocationEnabled": true,
          "isAndroidForegroundServiceEnabled": true
        }
      ]
    ],
    "experiments": {
      "typedRoutes": true,
      "reactCompiler": true
    },
    "extra": {
      "router": {},
      "eas": {
        "projectId": "9f1d6671-630f-4c7b-b11e-749375f31780"
      }
    }
  }
}